# ============================================
# AI Platform 环境变量配置 (模板)
# 复制此文件为 .env 并填入真实值:
#   cp .env.example .env
# ============================================

# Flask 环境 (development / testing / production)
FLASK_ENV=development
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# 应用密钥 — 生产环境请用强随机字符串 (python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=change-me-to-a-random-secret-key

# MySQL 数据库配置
MYSQL_USER=root
MYSQL_PASSWORD=your-database-password
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=ai_platform

# JWT 密钥 — 生产环境请用强随机字符串
JWT_SECRET_KEY=change-me-to-another-random-secret-key

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CORS 允许的来源 (生产环境请设置具体域名, 逗号分隔)
# CORS_ORIGINS=https://your-domain.com,https://app.your-domain.com

# ============================================
# 看门狗告警通知 (可选 — 不配置则禁用)
# ============================================
# SMTP 邮件告警
# WATCHDOG_SMTP_HOST=smtp.example.com
# WATCHDOG_SMTP_PORT=587
# WATCHDOG_SMTP_USER=alerts@example.com
# WATCHDOG_SMTP_PASSWORD=your-smtp-password
# WATCHDOG_SMTP_FROM_EMAIL=alerts@example.com
# WATCHDOG_SMTP_TO_EMAILS=admin@example.com,ml-team@example.com
# Webhook 告警 (钉钉/企业微信/飞书/Slack 通用)
# WATCHDOG_WEBHOOK_URL=https://hooks.example.com/watchdog-alert
# 告警冷却期 (秒)
# WATCHDOG_ALERT_COOLDOWN=3600
